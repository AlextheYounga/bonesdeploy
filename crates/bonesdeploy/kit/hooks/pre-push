#!/usr/bin/env bash
#
# pre-push — Local hook, symlinked to .git/hooks/pre-push
#
# Checks if we are pushing to the bonesdeploy-managed remote.
# If so, runs `bonesdeploy doctor` and aborts on any failure.
#
# Git passes the remote name and URL as arguments:
#   $1 = remote name
#   $2 = remote URL

set -euo pipefail
REMOTE_NAME="$1"
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

if [ ! -f ".bones/bones.toml" ]; then
	exit 0
fi

DEPLOY_REMOTE=$(grep -oP '^\s*remote_name\s*=\s*"\K[^"]+' .bones/bones.toml 2>/dev/null || true)
if [ "$REMOTE_NAME" != "$DEPLOY_REMOTE" ]; then
	exit 0
fi

if ! command -v bonesdeploy &>/dev/null; then
	echo "[bonesdeploy] bonesdeploy not found in PATH, skipping pre-push checks"
	exit 0
fi

echo "[bonesdeploy] Running pre-push checks..."
bonesdeploy doctor --local
