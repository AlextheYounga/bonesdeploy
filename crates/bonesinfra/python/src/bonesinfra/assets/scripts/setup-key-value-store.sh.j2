#!/usr/bin/env bash
set -euo pipefail

ENV="{{ env }}"
CONFIG="{{ config }}"
DATA_DIR="{{ data }}"
DEFAULT_PORT="{{ default_port }}"
PASSWORD_KEY="{{ password_key }}"
PORT_KEY="{{ port_key }}"
URL_KEY="{{ url_key }}"
UNIT="{{ unit }}"
RUNTIME_GROUP="{{ runtime_group }}"
BINARY="{{ binary }}"
SERVICE="{{ service }}"
PROJECT="{{ project }}"
PACKAGE_USER="{{ package_user }}"
UNIT_PATH="{{ unit_path }}"

password=$(sed -n "s/^${PASSWORD_KEY}=//p" "$ENV" | head -n1)
port=$(sed -n "s/^${PORT_KEY}=//p" "$ENV" | head -n1)
[ -n "$password" ] || password=$(openssl rand -hex 24)

if ! case "$port" in ""|*[!0-9]*) false;; esac; then
  for candidate in $(seq "$DEFAULT_PORT" $((DEFAULT_PORT + 100))); do
    if ! ss -ltn "sport = :$candidate" | grep -q LISTEN; then
      port=$candidate
      break
    fi
  done
fi
test -n "$port"

install -d -m 0755 -o root -g root /etc/bonesinfra/dbs
install -d -m 0700 -o "$PACKAGE_USER" -g "$PACKAGE_USER" "$DATA_DIR"

printf 'bind 127.0.0.1\nport %s\nprotected-mode yes\ndaemonize no\nrequirepass %s\ndir %s\n' "$port" "$password" "$DATA_DIR" > "$CONFIG"
chown "root:$PACKAGE_USER" "$CONFIG"
chmod 0640 "$CONFIG"

printf '[Unit]\nDescription=BonesInfra %s instance for %s\nAfter=network.target\n[Service]\nType=simple\nUser=%s\nGroup=%s\nExecStart=%s "%s"\nRestart=on-failure\n[Install]\nWantedBy=multi-user.target\n' \
  "$SERVICE" "$PROJECT" "$PACKAGE_USER" "$RUNTIME_GROUP" "$BINARY" "$CONFIG" > "$UNIT_PATH"
chown root:root "$UNIT_PATH"
chmod 0644 "$UNIT_PATH"

systemctl disable --now "${UNIT}.service" 2>/dev/null || true

sed -i "/^${PORT_KEY}=/d; /^${URL_KEY}=/d" "$ENV"
printf '%s=%s\n%s=%s\n%s=redis://:%s@127.0.0.1:%s/0\n' "$PASSWORD_KEY" "$password" "$PORT_KEY" "$port" "$URL_KEY" "$password" "$port" >> "$ENV"
