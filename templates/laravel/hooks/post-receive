#!/usr/bin/env bash
#
# post-receive — Remote hook, runs after refs are updated.
#
# Delegates checkout + release wiring to bonesremote, then
# calls deploy scripts.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)
HOOKS_LIB="$GIT_DIR/bones/hooks.sh"

if [ ! -f "$HOOKS_LIB" ]; then
    echo "[bonesdeploy] Missing hook library: $HOOKS_LIB"
    exit 1
fi

# shellcheck source=/dev/null
. "$HOOKS_LIB"
bones_init_remote_context "$GIT_DIR"

# Laravel specific: put the app into maintenance mode before checkout.
enter_maintenance_mode() {
	# Enter maintenance mode before checkout so the live worktree
	# is never served in a half-written state.
	if [ -f "$WORKTREE/artisan" ]; then
		echo "[bonesdeploy] Entering maintenance mode before checkout..."
		php "$WORKTREE/artisan" down || true
	fi
}

main() {
	bones_wire_release
	enter_maintenance_mode
	bones_run_deployment
	bones_post_deploy
}

main