daemon off;
worker_processes 1;
pid /run/{{ project_name }}/nginx.pid;
error_log stderr notice;

events {
    worker_connections 1024;
}

http {
    access_log stderr;
    client_body_temp_path /run/{{ project_name }}/client_body;
    proxy_temp_path /run/{{ project_name }}/proxy;
    fastcgi_temp_path /run/{{ project_name }}/fastcgi;
    uwsgi_temp_path /run/{{ project_name }}/uwsgi;
    scgi_temp_path /run/{{ project_name }}/scgi;

    server {
        listen unix:/run/{{ project_name }}/nginx.sock;
        root {{ live_root }};
        index index.html;

        location / {
            try_files $uri $uri/ /index.html;
        }

        location ^~ /.well-known/acme-challenge/ {
            try_files $uri =404;
        }
    }
}
