#!/usr/bin/env bash
#
# pre-receive — Remote hook, runs before refs are updated.
#
# Runs bonesremote doctor to validate the server environment,
# then calls pre-deploy to prepare the worktree for deployment.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)

HOOKS_DIR="$GIT_DIR/hooks"

echo "[bonesdeploy] Running remote doctor..."

if ! sudo bonesremote doctor; then
    echo "[bonesdeploy] Remote doctor reported issues. Push rejected."
    exit 1
fi

echo "[bonesdeploy] Doctor passed. Running pre-deploy..."

exec "$HOOKS_DIR/pre-deploy"
