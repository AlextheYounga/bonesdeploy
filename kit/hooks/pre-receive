#!/usr/bin/env bash
#
# pre-receive — Remote hook, runs before refs are updated.
#
# Runs bonesremote doctor to validate the server environment,
# then stages a release directly.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)
HOOKS_LIB="$GIT_DIR/bones/hooks.sh"

if [ ! -f "$HOOKS_LIB" ]; then
    echo "[bonesdeploy] Missing hook library: $HOOKS_LIB"
    exit 1
fi

# shellcheck source=/dev/null
. "$HOOKS_LIB"
bones_init_remote_context "$GIT_DIR"

main() {
	bones_run_doctor_remote
	bones_stage_release
}

main
