#!/usr/bin/env bash
#
# post-receive — Remote hook, runs after refs are updated.
#
# Checks out the latest commit into the staged release, then
# wires shared paths and calls deploy scripts.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)

BONES_TOML="$GIT_DIR/bones/bones.toml"
HOOKS_DIR="$GIT_DIR/hooks"
STAGED_RELEASE_FILE="$GIT_DIR/bones/.staged_release"

# Read deploy_root and branch from bones.toml
DEPLOY_ROOT=$(grep -E '^deploy_root\s*=' "$BONES_TOML" | head -1 | sed 's/.*=\s*"\(.*\)"/\1/')
BRANCH=$(grep -E '^branch\s*=' "$BONES_TOML" | head -1 | sed 's/.*=\s*"\(.*\)"/\1/')
STAGED_RELEASE=$(tr -d '[:space:]' < "$STAGED_RELEASE_FILE")
RELEASE_PATH="$DEPLOY_ROOT/releases/$STAGED_RELEASE"

if [ -z "$DEPLOY_ROOT" ] || [ -z "$BRANCH" ] || [ -z "$STAGED_RELEASE" ]; then
    echo "[gitbones] Error: Could not read deploy_root, branch, or staged release state"
    exit 1
fi

echo "[gitbones] Checking out $BRANCH to $RELEASE_PATH..."

git --work-tree="$RELEASE_PATH" --git-dir="$GIT_DIR" checkout -f "$BRANCH"

echo "[gitbones] Wiring shared paths for staged release..."
sudo gitbones-remote release wire --config "$BONES_TOML"

echo "[gitbones] Checkout complete. Running deploy..."

exec "$HOOKS_DIR/deploy"
