#!/usr/bin/env bash
#
# deploy — Remote hook, called by post-receive.
#
# Scans bones/deployment/ and runs each script in order against
# the staged release directory.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)

BONES_TOML="$GIT_DIR/bones/bones.toml"
DEPLOYMENT_DIR="$GIT_DIR/bones/deployment"
HOOKS_DIR="$GIT_DIR/hooks"
STAGED_RELEASE_FILE="$GIT_DIR/bones/.staged_release"

DEPLOY_ROOT=$(grep -E '^deploy_root\s*=' "$BONES_TOML" | head -1 | sed 's/.*=\s*"\(.*\)"/\1/')
STAGED_RELEASE=$(tr -d '[:space:]' < "$STAGED_RELEASE_FILE")
RELEASE_PATH="$DEPLOY_ROOT/releases/$STAGED_RELEASE"

if [ -z "$DEPLOY_ROOT" ] || [ -z "$STAGED_RELEASE" ]; then
    echo "[gitbones] Error: Could not read deploy_root or staged release state"
    exit 1
fi

if [ ! -d "$DEPLOYMENT_DIR" ]; then
    echo "[gitbones] No deployment directory found. Skipping deploy scripts."
else
    cd "$RELEASE_PATH"

    for script in "$DEPLOYMENT_DIR"/*; do
        [ -f "$script" ] || continue

        echo "[gitbones] Running $(basename "$script")..."

        if ! bash "$script"; then
            echo "[gitbones] Deployment script $(basename "$script") failed."
            sudo gitbones-remote release drop-failed --config "$BONES_TOML"
            exit 1
        fi
    done

    echo "[gitbones] All deployment scripts completed."
fi

sudo gitbones-remote release activate --config "$BONES_TOML"

echo "[gitbones] Running post-deploy..."

exec "$HOOKS_DIR/post-deploy"
