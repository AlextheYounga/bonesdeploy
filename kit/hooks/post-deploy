#!/usr/bin/env bash
#
# post-deploy — Remote hook, called by deploy.
#
# Runs bonesremote post-deploy, which hardens permissions
# back to the service user as configured in bones.toml.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)

BONES_TOML="$GIT_DIR/bones/bones.toml"

echo "[bonesdeploy] Running post-deploy (hardening permissions)..."

if ! sudo bonesremote post-deploy --config "$BONES_TOML"; then
    echo "[bonesdeploy] post-deploy failed."
    exit 1
fi

echo "[bonesdeploy] post-deploy complete. Deployment finished."
