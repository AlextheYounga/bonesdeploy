#!/usr/bin/env bash
#
# pre-deploy — Remote hook, called by pre-receive.
#
# Runs gitbones-remote prepare-release, which creates a pending
# release directory and prepares shared deployment state.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)

BONES_TOML="$GIT_DIR/bones/bones.toml"

echo "[gitbones] Running pre-deploy (preparing release)..."

if ! sudo gitbones-remote prepare-release --config "$BONES_TOML"; then
    echo "[gitbones] pre-deploy failed."
    exit 1
fi

echo "[gitbones] pre-deploy complete."
