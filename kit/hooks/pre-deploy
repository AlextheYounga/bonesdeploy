#!/usr/bin/env bash
#
# pre-deploy — Remote hook, called by pre-receive.
#
# Runs bonesremote pre-deploy, which changes ownership of
# the worktree to the deploy (ssh) user so that deployment
# scripts can write to it.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)

BONES_TOML="$GIT_DIR/bones/bones.toml"

echo "[bonesdeploy] Running pre-deploy (changing worktree ownership to deploy user)..."

if ! sudo bonesremote pre-deploy --config "$BONES_TOML"; then
    echo "[bonesdeploy] pre-deploy failed."
    exit 1
fi

echo "[bonesdeploy] pre-deploy complete."
