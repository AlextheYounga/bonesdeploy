#!/usr/bin/env bash
#
# pre-deploy — Remote hook, called by pre-receive.
#
# Runs bonesremote release stage, which creates a staged
# release directory and prepares shared deployment state.
#
# GIT_DIR is set by git to the bare repo path.

set -euo pipefail

GIT_DIR="${GIT_DIR:-.}"
GIT_DIR=$(cd "$GIT_DIR" && pwd)

BONES_TOML="$GIT_DIR/bones/bones.toml"

echo "[bonesdeploy] Running pre-deploy (preparing release)..."

if ! sudo bonesremote release stage --config "$BONES_TOML"; then
    echo "[bonesdeploy] pre-deploy failed."
    exit 1
fi

echo "[bonesdeploy] pre-deploy complete."
